FROM workspace-base

# workspace-base drops to USER dev; switch back to root for the
# system-level setup below (writes to /etc and /usr/local/bin).
USER root

# claude.d fragments + config builder (root-owned, applied at entrypoint).
COPY claude.d/ /etc/claude-code/claude.d/
COPY --chmod=0755 scripts/claude-config-builder /usr/local/bin/claude-config-builder
COPY --chmod=0755 scripts/entrypoint.sh /usr/local/bin/entrypoint.sh

# claude.d shell hooks (aliases, env) for every interactive bash.
RUN printf '%s\n' 'command -v claude-config-builder >/dev/null 2>&1 && eval "$(claude-config-builder shellenv)"' >> /etc/bash.bashrc

USER dev

# Install claude-code via native installer
RUN curl -fsSL https://claude.ai/install.sh | bash

# Make claude available via PATH
RUN echo 'export PATH="$HOME/.local/bin:$PATH"' >> /home/dev/.profile

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
CMD ["bash"]
