FROM workspace-base

# claude.d fragments + merge script (root-owned, executed at entrypoint).
COPY claude.d/ /etc/claude-code/claude.d/
COPY --chmod=0755 scripts/merge-claude-config.sh /usr/local/bin/merge-claude-config.sh
COPY --chmod=0755 scripts/entrypoint.sh /usr/local/bin/entrypoint.sh

# Starter ~/.claude/CLAUDE.md — installed by the entrypoint on first
# start (does NOT overwrite an existing user file). Ships project
# defaults (e.g. no Claude attribution in commits/PRs). Operators
# edit ~/.claude/CLAUDE.md inside their running container to add or
# override preferences; subsequent starts leave their edits alone.
COPY .claude/CLAUDE.md /etc/claude-code/CLAUDE.md.starter

USER dev

# Install claude-code via native installer
RUN curl -fsSL https://claude.ai/install.sh | bash

# Make claude available via PATH
RUN echo 'export PATH="$HOME/.local/bin:$PATH"' >> /home/dev/.profile

# Default flags via shell alias — Claude Code does not honor env vars for these.
RUN echo 'alias claude='"'"'claude --model "opus[1m]" --effort max'"'"'' >> /home/dev/.bashrc

# Max effort does not persist in settings.json, set as env (covers non-interactive shells).
ENV CLAUDE_CODE_EFFORT_LEVEL=max

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
CMD ["bash"]
